{
  "name": "agentradar",
  "version": "2.0.3",
  "description": "Terminal dashboard that monitors your local AI tooling ecosystem — coding agents, MCP servers, LLM models, and token metrics.",
  "type": "module",
  "bin": {
    "agentradar": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:ink --external:react --external:ps-list",
    "start": "node dist/index.js",
    "release": "release-it"
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "agent",
    "cli",
    "tui",
    "dashboard",
    "ai",
    "coding",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^15.0.0",
    "glob": "^10.3.0",
    "ink": "^5.2.1",
    "ps-list": "^9.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "esbuild": "^0.20.0",
    "release-it": "^20.2.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
